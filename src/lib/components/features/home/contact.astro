---
import { ContactForm } from '$lib/components/forms';
import { ExternalLink, GlassCard } from '$lib/components/ui';
import { EMAIL_ADDRESS, LINKEDIN_ADDRESS } from '$lib/config';
import User from '@lucide/astro/icons/user';
import Mail from '@lucide/astro/icons/mail';
---

<section
  class="full-width bg-surface-container-low py-12 md:py-16 lg:py-24"
  id="contact"
>
  <div class="content-width">
    <!-- Section header -->
    <div
      class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10 md:mb-12 lg:mb-16"
    >
      <p
        class="label-md text-muted-foreground font-bold tracking-[0.2em] uppercase"
      >
        Contact
      </p>

      <div
        class="hidden md:block flex-1 h-px mx-8 bg-linear-to-r from-transparent via-gray-300 to-transparent opacity-60"
      >
      </div>
    </div>

    <!-- Heading -->
    <h2
      class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-on-surface mb-8 md:mb-10"
    >
      Let’s Build Something <br class="hidden sm:block" />
      Robust.
    </h2>

    <!-- Glass container -->
    <GlassCard
      class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 lg:gap-12 p-6 md:p-8 lg:p-10"
    >
      <!-- Info -->
      <div class="space-y-5 md:space-y-6">
        <h3 class="text-xl md:text-2xl font-semibold">Get In Touch</h3>

        <p class="text-on-surface leading-relaxed">
          Currently open to architectural consulting and lead engineering roles.
          Reach out for a technical deep-dive.
        </p>

        <!-- Contact items -->
        <ul class="flex flex-col gap-3 md:gap-4">
          <!-- Email -->
          <li class="flex items-center gap-3 text-card-foreground">
            <Mail class="w-5 h-5 shrink-0" stroke-width="1.5" />

            <ExternalLink
              href={`mailto:${EMAIL_ADDRESS}`}
              class="text-sm font-semibold break-all"
            >
              {EMAIL_ADDRESS}
            </ExternalLink>
          </li>

          <!-- LinkedIn -->
          <li class="flex items-center gap-3 text-card-foreground">
            <User class="w-5 h-5 shrink-0" stroke-width="1.5" />

            <ExternalLink
              href={LINKEDIN_ADDRESS}
              class="text-sm font-semibold break-all"
            >
              LinkedIn Profile
            </ExternalLink>
          </li>
        </ul>

        <!-- CTA -->
        <p class="text-sm text-on-surface">
          Open to discussions via email or LinkedIn.
        </p>
      </div>

      <!-- Form -->
      <div>
        <ContactForm client:visible />
      </div>
    </GlassCard>
  </div>
</section>
