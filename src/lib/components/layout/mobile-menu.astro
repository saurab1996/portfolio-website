---
import { HeaderNavigation } from '$lib/components/navigation';
import { ResumeButton } from '$lib/components/buttons';
import MenuIcon from '@lucide/astro/icons/menu';
import XIcon from '@lucide/astro/icons/x';
import { Logo } from '$lib/components/ui';
const currentPath = Astro.url.pathname;
---

<!-- Trigger -->
<button
  id="mobile-menu-trigger"
  class="lg:hidden cursor-pointer"
  aria-label="Open menu"
>
  <MenuIcon size={28} class="cursor-pointer" />
</button>

<!-- Backdrop -->
<div
  id="mobile-menu-backdrop"
  class="fixed inset-0 z-40 bg-black/50 hidden"
  aria-hidden="true"
>
</div>

<!-- Sheet panel (slides in from right) -->
<div
  id="mobile-menu-sheet"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile menu"
  class="fixed inset-y-0 right-0 z-50 w-3/4 max-w-sm bg-background shadow-xl
         translate-x-full transition-transform duration-300 ease-in-out"
>
  <!-- Header -->
  <div class="flex flex-row items-center justify-between p-4 border-b">
    <a href="/" aria-label="Go to homepage">
      <Logo />
    </a>
    <button
      id="mobile-menu-close"
      class="cursor-pointer"
      aria-label="Close menu"
    >
      <XIcon size={28} class="cursor-pointer" />
    </button>
  </div>

  <!-- Content -->
  <div class="flex flex-col gap-6 px-4 pt-6">
    <HeaderNavigation {currentPath} class="flex flex-col items-start gap-4" />
    <ResumeButton size="lg" />
  </div>
</div>

<script>
  const trigger = document.getElementById('mobile-menu-trigger')!;
  const sheet = document.getElementById('mobile-menu-sheet')!;
  const backdrop = document.getElementById('mobile-menu-backdrop')!;
  const closeBtn = document.getElementById('mobile-menu-close')!;

  function openMenu() {
    sheet.classList.remove('translate-x-full');
    backdrop.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    sheet.classList.add('translate-x-full');
    backdrop.classList.add('hidden');
    document.body.style.overflow = '';
  }

  trigger.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);
  backdrop.addEventListener('click', closeMenu);

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
