---
import "../styles/global.css";
import { Header, Footer } from "$lib/components/layout";
import { PageSchema, SEO } from "$lib/components/seo";
import { CDN_URL } from "$lib/config";
import type { SEOMeta } from "$lib/types/seo.types";
const currentPath = Astro.url.pathname;
const params = Astro.params;

interface Props {
  meta?: Partial<SEOMeta> | undefined;
}

const { meta }: Props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <SEO override={meta} />
    <PageSchema />

    <link rel="dns-prefetch" href={CDN_URL} />
    <link rel="preconnect" href={CDN_URL} crossorigin="anonymous" />
    <link
      rel="preload"
      href={`${CDN_URL}/fonts/inter-v20-latin-regular.woff2`}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href={`${CDN_URL}/fonts/inter-v20-latin-700.woff2`}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <script is:inline>
      const theme =
        localStorage.getItem("theme") ??
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <Header client:load {currentPath} {params} />

      <main
        class="flex-1 pt-32 md:pt-40 pb-20 px-4 lg:px-0 content-width w-full space-y-24 md:space-y-32 lg:space-y-40"
      >
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
